<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 265" role="img" aria-label="System identity: {{ entity }}">
  <title>System Identity — {{ entity }}</title>
  <defs>
    <style>
      .id-key {
        fill: #E8A838;
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        font-size: 13px;
        font-weight: 600;
      }
      .id-val {
        fill: #F0EBE1;
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        font-size: 13px;
      }
      .id-bracket {
        fill: #8C8479;
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        font-size: 13px;
      }
      .id-arrow {
        fill: #A8762A;
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        font-size: 12px;
      }
      .id-quote {
        fill: #8C8479;
        font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
        font-size: 12px;
        font-style: italic;
      }
    </style>
  </defs>

  <text class="id-key" x="20" y="24">entity</text>
  <text class="id-val" x="170" y="24">{{ entity }}</text>

  <text class="id-key" x="20" y="50">role</text>
  <text class="id-val" x="170" y="50">{{ role }}</text>

  <text class="id-key" x="20" y="76">location</text>
  <text class="id-val" x="170" y="76">{{ location }}</text>

  <text class="id-key" x="20" y="102">architecture</text>
  <text class="id-bracket" x="170" y="102">[{{ architecture | join(", ") }}]</text>

  <text class="id-key" x="20" y="140">philosophy</text>
  {% for quote in philosophy %}
  <text class="id-arrow" x="40" y="{{ 165 + loop.index0 * 23 }}">→</text>
  <text class="id-quote" x="60" y="{{ 165 + loop.index0 * 23 }}">&#x201C;{{ quote }}&#x201D;</text>
  {% endfor %}

  {% set focus_y = 165 + (philosophy | length) * 23 + 20 %}
  <text class="id-key" x="20" y="{{ focus_y }}">current_focus</text>
  <text class="id-val" x="170" y="{{ focus_y }}">{{ current_focus }}</text>
</svg>
